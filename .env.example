# Google Gemini API key (REQUIRED for answer generation).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# LLM model used for generation (default: gemini-2.5-flash)
# LLM_MODEL=gemini-2.5-flash

# Local sentence-transformers embedding model (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB persistence directory (default: ./data/chroma_db)
# CHROMA_PERSIST_DIR=./data/chroma_db

# Chunking configuration
# MAX_CHUNK_SIZE=1500
# CHUNK_OVERLAP=200

# Retrieval configuration
# RETRIEVAL_TOP_K=5

# Comma-separated list of allowed frontend origins for CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501,http://localhost:8080

# Optional backend API key. Leave empty to disable auth (local/dev). When set,
# clients must send a matching X-API-Key header (frontend uses VITE_API_KEY).
# API_KEY=
